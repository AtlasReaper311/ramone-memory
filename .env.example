# ramone-memory configuration. Every value here has the same default
# baked into app/config.py and docker-compose.yml, so the stack boots
# with no .env at all; copy this file only to override.

# Ollama on the host (owns the GPU). host.docker.internal resolves on
# native Linux via the compose extra_hosts mapping.
OLLAMA_HOST=http://host.docker.internal:11434
CHAT_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# Chroma runs inside this compose stack; leave as-is unless pointing
# at a shared external Chroma.
CHROMA_HOST=chromadb
CHROMA_PORT=8000
COLLECTION_NAME=ramone_memory

# Retrieval: memories injected per turn, and the size cap on the block.
TOP_K=3
MAX_INJECTED_CHARS=2400

# Session lifecycle: idle seconds before a session is summarised, how
# often the reaper checks, and how many raw turns ride into the memory.
SESSION_IDLE_SECONDS=300
REAPER_INTERVAL_SECONDS=30
RAW_TURNS_KEPT=8

# Optional base system prompt used only when the caller sends none.
SYSTEM_PROMPT=

# Model context window and summariser temperature.
NUM_CTX=4096
TEMPERATURE=0.2

LOG_LEVEL=INFO
